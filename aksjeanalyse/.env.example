# AksjeAnalyse — Environment Variables
# Copy this file to .env and adjust values as needed.

# Database (dev: SQLite, prod: PostgreSQL)
# DATABASE_URL=sqlite+aiosqlite:///./aksjeanalyse.db
DATABASE_URL=postgresql+asyncpg://aksjeanalyse:aksjeanalyse_dev@localhost:5432/aksjeanalyse

# Redis (optional, for production caching)
# REDIS_URL=redis://localhost:6379/0

# Frontend URL (for CORS)
# FRONTEND_URL=http://localhost:3000
