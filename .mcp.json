{
	"mcpServers":
	{
		"unrealMCP":
		{
			"command": "uv",
			"args": [
				"--directory",
				"/Users/leovonschwind/.claude/mcp-servers/unreal-mcp/Python",
				"run",
				"unreal_mcp_server.py"
			]
		},
		"blender":
		{
			"command": "uvx",
			"args": [
				"blender-mcp"
			],
			"env":
			{
				"BLENDER_HOST": "localhost",
				"BLENDER_PORT": "9876"
			}
		},
		"unreal-mcp":
		{
			"type": "http",
			"url": "http://127.0.0.1:8000/mcp"
		}
	}
}